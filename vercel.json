{
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/api/admin"
    },
    {
      "source": "/api/config",
      "destination": "/api/config"
    },
    {
      "source": "/api/login",
      "destination": "/api/login"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.js?url=/$1"
    }
  ]
}
