{
  "globalBypassConfig": false,
  "proxies": [
    {
      "name": "gemini",
      "domain": "generativelanguage.googleapis.com",
      "mode": "filtered",
      "auth": {
        "type": "api-key",
        "sources": [
          "x-goog-api-key",
          "authorization-bearer"
        ]
      },
      "headers": {
        "set": {
          "host": "{target_hostname}",
          "origin": "{target_origin}",
          "referer": "{target_url}"
        },
        "removeRequest": [
          "x-goog-api-key",
          "authorization"
        ],
        "removeResponse": [
          "content-encoding",
          "transfer-encoding",
          "connection",
          "strict-transport-security"
        ]
      },
      "forwardedHeaders": true
    },
    {
      "name": "nvidia",
      "domain": "integrate.api.nvidia.com",
      "mode": "simple",
      "auth": null,
      "headers": {
        "removeRequest": [
          "host",
          "content-length",
          "connection"
        ],
        "removeResponse": [
          "content-encoding",
          "content-length",
          "transfer-encoding",
          "connection"
        ]
      },
      "forwardedHeaders": false
    }
  ],
  "defaultProxy": null
}
